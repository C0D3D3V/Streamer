# Server
PORT=3000
DATA_DIR=./data

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Authelia OIDC
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=streamer
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://streamer.example.com/auth/callback

# Hardware acceleration
# Options: auto (detect at startup), qsv, vaapi, libx264
FFMPEG_ENCODER=auto
# Only needed if FFMPEG_ENCODER=vaapi (default works for most Intel setups)
VAAPI_DEVICE=/dev/dri/renderD128

# Docker (only used by entrypoint)
PUID=1000
PGID=1000
UMASK=022
